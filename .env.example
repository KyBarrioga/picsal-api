DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase Postgres
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Supabase Auth
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]
SUPABASE_JWKS_URL=https://[YOUR-PROJECT-REF].supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://[YOUR-PROJECT-REF].supabase.co/auth/v1
SUPABASE_JWT_SECRET=[YOUR-SUPABASE-JWT-SECRET]
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ALGORITHM=HS256

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=[YOUR-ACCOUNT-ID]
CLOUDFLARE_R2_ACCESS_KEY_ID=[YOUR-ACCESS-KEY]
CLOUDFLARE_R2_SECRET_ACCESS_KEY=[YOUR-SECRET-KEY]
CLOUDFLARE_R2_BUCKET=picsal-assets
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.example.com
